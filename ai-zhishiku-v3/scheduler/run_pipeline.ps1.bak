# 知识库自动化采集 - Windows 本地定时任务脚本
# 运行 pipeline/pipeline.py，记录日志，自动清理过期日志

param(
    [string]$Sources = "github,rss",
    [int]$Limit = 20,
    [int]$RetentionDays = 30
)

$ErrorActionPreference = "Continue"

$ScriptDir = Split-Path -Parent $MyInvocation.MyCommand.Path
$ProjectDir = Resolve-Path "$ScriptDir\.."
$LogDir = Join-Path $ProjectDir "logs"

New-Item -ItemType Directory -Force -Path $LogDir | Out-Null

$Timestamp = (Get-Date).ToUniversalTime().ToString("yyyy-MM-dd_HHmmss")
$LogFile = Join-Path $LogDir "collect_$Timestamp.log"
$HistoryLog = Join-Path $LogDir "collect_history.log"

$Utf8Encoding = New-Object System.Text.UTF8Encoding $false

function Write-Log {
    param([string]$Message)
    $Line = "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] $Message"
    [System.IO.File]::AppendAllText($LogFile, $Line + "`r`n", $Utf8Encoding)
    Write-Host $Line
}

function Clear-OldLogs {
    param([int]$Days)
    Write-Log "清理 $Days 天前的日志..."
    $Cutoff = (Get-Date).AddDays(-$Days)
    Get-ChildItem -LiteralPath $LogDir -Filter "collect_*.log" |
        Where-Object { $_.LastWriteTime -lt $Cutoff } |
        Remove-Item -Force
}

function Invoke-Pipeline {
    Write-Log "========== 知识库采集开始 =========="
    Write-Log "参数: sources=$Sources, limit=$Limit"

    $Stopwatch = [System.Diagnostics.Stopwatch]::StartNew()
    $ExitCode = 0
    $TempOutputFile = Join-Path $LogDir "temp_output.txt"

    try {
        Push-Location -LiteralPath $ProjectDir
        $env:PYTHONIOENCODING = "utf-8"
        $env:PYTHONUTF8 = "1"
        python -u pipeline\pipeline.py --sources $Sources --limit $Limit --verbose | Out-File -FilePath $TempOutputFile -Encoding utf8
        $ExitCode = $LASTEXITCODE
        Pop-Location
    }
    catch {
        $ExitCode = 1
        Pop-Location
    }

    if (Test-Path $TempOutputFile) {
        $Content = Get-Content -Path $TempOutputFile -Encoding utf8 -Raw
        [System.IO.File]::AppendAllText($LogFile, $Content, $Utf8Encoding)
        Remove-Item $TempOutputFile -Force
    }

    $Stopwatch.Stop()
    $Duration = [math]::Round($Stopwatch.Elapsed.TotalSeconds, 0)

    if ($ExitCode -eq 0) {
        Write-Log "采集成功，耗时 ${Duration}s"
    } else {
        Write-Log "采集失败，退出码: $ExitCode，耗时 ${Duration}s"
    }

    Write-Log "========== 采集结束 =========="
    return @{ ExitCode = $ExitCode; Duration = $Duration }
}

$Result = Invoke-Pipeline

$LogContent = [System.IO.File]::ReadAllText($LogFile, $Utf8Encoding)
[System.IO.File]::AppendAllText($HistoryLog, $LogContent + "`r`n", $Utf8Encoding)

Clear-OldLogs -Days $RetentionDays

if ($Result.ExitCode -ne 0) {
    throw "采集失败，退出码: $($Result.ExitCode)"
}